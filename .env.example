# Copy to .env.local and fill in. Never commit real secrets.

# --- Clerk (auth) — https://dashboard.clerk.com ---
# Phase 0: optional. App boots without these; /sign-in shows a setup notice.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Supabase (Postgres) — https://supabase.com/dashboard ---
# Phase 0: optional. /api/health reports "not_configured" without these.
# Run supabase/schema.sql in the Supabase SQL editor to create the
# health_check table.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only; used by API routes. Do NOT expose with a NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic (wireframe generation) — https://platform.claude.com ---
# Phase 1: required for /studio generation. /api/generate returns a clear
# 503 without it. Server-only.
ANTHROPIC_API_KEY=
