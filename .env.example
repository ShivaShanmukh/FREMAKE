# Copy to .env.local and fill in. Never commit real secrets.

# --- Clerk (auth) — https://dashboard.clerk.com ---
# Phase 0: optional. App boots without these; /sign-in shows a setup notice.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Supabase (Postgres) — https://supabase.com/dashboard ---
# Phase 0: optional. /api/health reports "not_configured" without these.
# Run supabase/schema.sql in the Supabase SQL editor to create the
# health_check table.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only; used by API routes. Do NOT expose with a NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=

# --- Credit ledger (Postgres) ---
# Required for the credit system. Local dev:
#   docker run -d --name frmake-pg -e POSTGRES_PASSWORD=frmake_dev \
#     -e POSTGRES_DB=frmake -p 5434:5432 postgres:16
#   npm run db:migrate
# For hosted Supabase, use the project's Postgres connection string.
DATABASE_URL=

# DEV ONLY — never set in a deployed environment. When Clerk keys are
# absent and this is 1, API routes accept an `x-dev-user` header as the
# user identity so the ledger can be exercised before Clerk is configured.
# Dead code once Clerk keys are set.
DEV_AUTH_BYPASS=

# --- Stripe (credit top-ups) — https://dashboard.stripe.com ---
# Test-mode keys are fine. Without these, /api/billing/* returns 503 and
# the Buy credits menu shows the error.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Signing secret for the webhook endpoint. Local dev: `stripe listen
# --forward-to localhost:3000/api/billing/webhook` prints one (whsec_...).
STRIPE_WEBHOOK_SECRET=

# --- Sentry (error monitoring) — https://sentry.io ---
# Create a Next.js project, then Settings → Client Keys (DSN). Without
# these, errors are never reported — app boots and CI builds fine either way.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Optional — only needed for source-map upload during `npm run build`.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- PostHog (analytics) — https://posthog.com ---
# Project API key (Project Settings) — this is a write-only ingestion
# key by design, safe to reuse for both client and server tracking.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# --- Anthropic (wireframe generation) — https://platform.claude.com ---
# Phase 1: required for /studio generation. /api/generate returns a clear
# 503 without it. Server-only.
ANTHROPIC_API_KEY=
